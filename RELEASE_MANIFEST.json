    "gavang_stream_key_hls_flv_fast_path": true,
    "phaohoa_signed_url_registry_with_expiry_check": true,
    "workflow_cancel_in_progress": false,
    "schedule": "*/30 * * * *",
    "fresh_source_playlist_is_authoritative_after_scanner_success": true,
    "debug_stream_urls_schema_fallback": true,
    "missing_debug_stream_index_fallback": true,
    "fresh_stream_replaces_same_url_last_good": true,
    "per_fresh_url_final_decision_audit": true,
    "workflow_fails_on_unresolved_fresh_stream": true
