    "sources/gavang.py": "4.4.28-GAVANG-FAST-STREAMKEY-REGISTRY",
    "sources/xoilac.py": "4.4.28-XOILAC-FAST-REGISTRY-GUARD",
    "sources/colatv.py": "4.4.28-COLATV-FAST-REGISTRY-GUARD",
    "sources/phaohoa.py": "4.4.28-PHAOHOA-FAST-SIGNED-REGISTRY",
    "sources/fast_registry_support.py": "4.4.28-shared-registry-support"
