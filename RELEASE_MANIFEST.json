  "critical_policies": {
    "all_live_verified_only": true,
    "metadata_cards_debug_only": true,
    "last_known_good_reprobe": true,
    "scan_window_past_minutes": 150,
    "scan_window_future_minutes": 180,
    "fast_registry_future_minutes_for_shared_channels": 15,
